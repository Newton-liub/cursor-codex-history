{
  "name": "cursor-codex-history",
  "version": "0.1.0",
  "private": true,
  "description": "Backup, index, export, archive, recover, and delete Codex history for Cursor without mutating internal Cursor DB.",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
